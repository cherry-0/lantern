OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_KEY=
SECRET_KEY=

# ── Local model inference (verify/ pipeline) ──────────────────────────────────
# Set INFER_LOCAL=true to route perturbation + evaluation through local Ollama
# instead of OpenRouter. OPENROUTER_API_KEY is not required when enabled.
INFER_LOCAL=false

# Ollama base URL (default: http://localhost:11434/v1)
LOCAL_MODEL_URL=

# Override auto-selected local model (auto: gemma4:26b ≥8 GB RAM, else gemma4:e4b)
LOCAL_MODEL_NAME=

# Per-pipeline model overrides (only used when INFER_LOCAL=true or as OpenRouter model IDs)
PERTURBATION_TEXT_MODEL=
PERTURBATION_VISION_MODEL=
EVAL_MODEL=

# Evaluation HTTP timeout in seconds (default: 300 local, 60 OpenRouter)
EVAL_TIMEOUT=

# Enable verbose logging (true/false)
VERBOSE=